<mvc:View
  controllerName="purchaseorders.controller.Detail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true">

  <Page
    id="detailPage"
    title="Bestellung {PurchaseOrder}"
    showNavButton="true"
    navButtonPress=".onNavBack">

    <headerContent>
      <Button text="Genehmigen" type="Accept" press=".onApprove"
        visible="{viewModel>/canAct}" />
      <Button text="Ablehnen" type="Reject" press=".onReject"
        visible="{viewModel>/canAct}" />
    </headerContent>

    <content>
      <Panel headerText="Allgemeine Informationen" class="sapUiMediumMargin">
        <content>
          <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
            labelSpanL="4" labelSpanM="4" columnsL="2" columnsM="2">
            <form:content>
              <Label text="Bestellnummer" />
              <Text text="{PurchaseOrder}" />

              <Label text="Bestelltyp" />
              <Text text="{PurchaseOrderType}" />

              <Label text="Lieferant" />
              <Text text="{Supplier}" />

              <Label text="Status" />
              <ObjectStatus
                text="{path: 'PurchasingProcessingStatus', formatter: '.formatStatusText'}"
                state="{path: 'PurchasingProcessingStatus', formatter: '.formatStatusState'}" />

              <Label text="Bestelldatum" />
              <Text text="{path: 'PurchaseOrderDate', formatter: '.formatDate'}" />

              <Label text="Erstellt am" />
              <Text text="{path: 'CreationDate', formatter: '.formatDate'}" />

              <Label text="Erstellt von" />
              <Text text="{CreatedByUser}" />

              <Label text="Gesamtbetrag" />
              <Text
                text="{parts: [{path: 'PurgReleaseTimeTotalAmount'},{path: 'DocumentCurrency'}], formatter: '.formatAmount'}" />
            </form:content>
          </form:SimpleForm>
        </content>
      </Panel>

      <Panel headerText="Organisationsdaten" class="sapUiMediumMargin">
        <content>
          <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
            labelSpanL="4" labelSpanM="4" columnsL="2" columnsM="2">
            <form:content>
              <Label text="Buchungskreis" />
              <Text text="{CompanyCode}" />

              <Label text="Einkaufsorg." />
              <Text text="{PurchasingOrganization}" />

              <Label text="Einkäufergruppe" />
              <Text text="{PurchasingGroup}" />

              <Label text="Währung" />
              <Text text="{DocumentCurrency}" />

              <Label text="Zahlungsbedingung" />
              <Text text="{PaymentTerms}" />

              <Label text="Skonto 1 (Tage)" />
              <Text text="{CashDiscount1Days}" />
            </form:content>
          </form:SimpleForm>
        </content>
      </Panel>
    </content>
  </Page>

</mvc:View>