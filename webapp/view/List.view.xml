<mvc:View controllerName="purchaseorders.controller.List"
  xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" displayBlock="true">

  <Page id="listPage" title="Bestellungen verwalten">
    <content>
      <Table id="ordersTable" items="{/ZOSO_C_PurchaseOrder}"
        growing="true" growingThreshold="15" growingScrollToLoad="false">
        <headerToolbar>
          <Toolbar>
            <Title text="Bestellungen" />
            <ToolbarSpacer />
            <SearchField placeholder="Suchen..." search=".onSearch" width="20rem" />
          </Toolbar>
        </headerToolbar>
        <columns>
          <Column><Text text="Bestellnummer" /></Column>
          <Column><Text text="Lieferant" /></Column>
          <Column><Text text="Status" /></Column>
          <Column><Text text="Betrag" /></Column>
        </columns>
        <items>
          <ColumnListItem type="Navigation" press=".onOrderPress">
            <cells>
              <Text text="{PurchaseOrder}" />
              <Text text="{Supplier}" />
              <ObjectStatus text="{PurchasingProcessingStatus}" />
              <Text text="{amount}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>
  </Page>

</mvc:View>