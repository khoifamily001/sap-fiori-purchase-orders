<mvc:View controllerName="purchaseorders.controller.List"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  displayBlock="true">

  <Page id="listPage" title="Bestellungen verwalten">
    <content>

      <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop">
        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
          <Button id="btnToggleFilter" text="Filter ausblenden" icon="sap-icon://filter"
            type="Transparent" press=".onToggleFilter"/>
          <Text id="txtFilterCount" text="" class="sapUiSmallMarginEnd"/>
        </HBox>

        <VBox id="filterPanel">
          <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
            <VBox class="sapUiSmallMarginEnd" width="220px">
              <Label text="Suche"/>
              <SearchField id="searchField" placeholder="Bestellnummer, Lief..."
                search=".onSearch" liveChange=".onLiveSearch" width="100%"/>
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="200px">
              <Label text="Status"/>
              <Select id="filterStatus" change=".onFilter" width="100%">
                <core:Item key="" text="Alle Status"/>
                <core:Item key="01" text="Version in Arbeit"/>
                <core:Item key="02" text="Aktiv"/>
                <core:Item key="03" text="In Freigabe"/>
                <core:Item key="04" text="Freigabe teilweise"/>
                <core:Item key="05" text="Freigabe abgeschlossen"/>
                <core:Item key="08" text="Abgelehnt"/>
                <core:Item key="11" text="In Verteilung"/>
                <core:Item key="12" text="Fehler bei Verteilung"/>
                <core:Item key="13" text="Verteilt"/>
                <core:Item key="14" text="In Vorbereitung"/>
                <core:Item key="26" text="In externer Genehmigung"/>
              </Select>
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="180px">
              <Label text="Einkaufsorg."/>
              <Select id="filterPurchOrg" change=".onFilter" width="100%">
                <core:Item key="" text="Alle"/>
                <core:Item key="1710" text="1710"/>
              </Select>
            </VBox>
            <VBox width="180px">
              <Label text="Buchungskreis"/>
              <Select id="filterCompany" change=".onFilter" width="100%">
                <core:Item key="" text="Alle"/>
                <core:Item key="1710" text="1710"/>
              </Select>
            </VBox>
          </HBox>
        </VBox>

        <HBox class="sapUiSmallMarginBottom">
          <Button text="Erstellen" icon="sap-icon://add" type="Emphasized"
            press=".onCreatePress" class="sapUiSmallMarginEnd"/>
          <Button text="Exportieren" icon="sap-icon://download" press=".onExportPress"/>
        </HBox>
      </VBox>

      <Table id="ordersTable"
        items="{/ZOSO_C_PurchaseOrder}"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="false"
        updateFinished=".onTableUpdateFinished">
        <columns>
          <Column width="150px"><Text text="Bestellnummer"/></Column>
          <Column><Text text="Lieferant"/></Column>
          <Column width="130px"><Text text="Bestelldatum"/></Column>
          <Column width="130px"><Text text="Erstellt am"/></Column>
          <Column width="160px"><Text text="Status"/></Column>
          <Column width="110px"><Text text="Einkaufsorg."/></Column>
          <Column width="110px"><Text text="Buchungskreis"/></Column>
          <Column width="140px" hAlign="End"><Text text="Gesamtbetrag"/></Column>
        </columns>
        <items>
          <ColumnListItem type="Navigation" press=".onOrderPress">
            <cells>
              <Text text="{PurchaseOrder}"/>
              <Text text="{Supplier}"/>
              <Text text="{path: 'PurchaseOrderDate', type: 'sap.ui.model.type.Date', formatOptions: {style: 'medium', UTC: true}}"/>
              <Text text="{path: 'CreationDate', type: 'sap.ui.model.type.Date', formatOptions: {style: 'medium', UTC: true}}"/>
              <ObjectStatus
                text="{path: 'PurchasingProcessingStatus', formatter: '.formatStatusText'}"
                state="{path: 'PurchasingProcessingStatus', formatter: '.formatStatusState'}"/>
              <Text text="{PurchasingOrganization}"/>
              <Text text="{CompanyCode}"/>
              <Text text="{parts: [{path: 'PurgReleaseTimeTotalAmount'},{path: 'DocumentCurrency'}], formatter: '.formatAmount'}"/>
            </cells>
          </ColumnListItem>
        </items>
      </Table>

      <!-- CREATE DIALOG with full mockup form -->
      <Dialog id="createDialog" title="Bestellung erstellen" contentWidth="900px" verticalScrolling="true">
        <content>
          <VBox class="sapUiMediumMargin">
            
            <!-- Allgemeine Informationen -->
            <Panel headerText="Allgemeine Informationen" class="sapUiMediumMarginBottom">
              <content>
                <VBox class="sapUiSmallMargin">
                  <HBox wrap="Wrap">
                    <VBox width="48%" class="sapUiMediumMarginEnd">
                      <Label text="Lieferant" required="true"/>
                      <Select id="cLieferant" selectedKey="{create>/lieferant}" width="100%" class="sapUiSmallMarginBottom">
                        <core:Item key="" text="Bitte wählen..."/>
                        <core:Item key="USSU-VSF01" text="USSU-VSF01"/>
                        <core:Item key="USSU-VSF02" text="USSU-VSF02"/>
                        <core:Item key="USSU-VSF04" text="USSU-VSF04"/>
                        <core:Item key="USSU-VSF05" text="USSU-VSF05"/>
                        <core:Item key="USSU-VSF06" text="USSU-VSF06"/>
                        <core:Item key="USSU-VSF07" text="USSU-VSF07"/>
                        <core:Item key="USSU-VSF08" text="USSU-VSF08"/>
                      </Select>
                      <Label text="Bestelldatum" required="true"/>
                      <DatePicker id="cBestelldatum" value="{create>/bestelldatum}" width="100%" class="sapUiSmallMarginBottom"
                        valueFormat="dd.MM.yyyy" displayFormat="dd.MM.yyyy"/>
                      <Label text="Priorität"/>
                      <Select id="cPrioraet" selectedKey="{create>/prioritaet}" width="100%" class="sapUiSmallMarginBottom">
                        <core:Item key="Niedrig" text="Niedrig"/>
                        <core:Item key="Mittel" text="Mittel"/>
                        <core:Item key="Hoch" text="Hoch"/>
                      </Select>
                      <Label text="Zahlungsbedingungen"/>
                      <Select id="cZahlung" selectedKey="{create>/zahlung}" width="100%">
                        <core:Item key="Netto 30 Tage" text="Netto 30 Tage"/>
                        <core:Item key="Netto 14 Tage" text="Netto 14 Tage"/>
                        <core:Item key="Sofort" text="Sofort"/>
                      </Select>
                    </VBox>
                    <VBox width="48%">
                      <Label text="Kategorie" required="true"/>
                      <Select id="cKategorie" selectedKey="{create>/kategorie}" width="100%" class="sapUiSmallMarginBottom">
                        <core:Item key="" text="Bitte wählen..."/>
                        <core:Item key="Rohstoffe" text="Rohstoffe"/>
                        <core:Item key="Büromaterial" text="Büromaterial"/>
                        <core:Item key="IT-Equipment" text="IT-Equipment"/>
                        <core:Item key="Werkzeuge" text="Werkzeuge"/>
                        <core:Item key="Verpackungsmaterial" text="Verpackungsmaterial"/>
                        <core:Item key="Ersatzteile" text="Ersatzteile"/>
                      </Select>
                      <Label text="Lieferdatum" required="true"/>
                      <DatePicker id="cLieferdatum" value="{create>/lieferdatum}" width="100%" class="sapUiSmallMarginBottom"
                        valueFormat="dd.MM.yyyy" displayFormat="dd.MM.yyyy"/>
                      <Label text="Einkäufer" required="true"/>
                      <Select id="cEinkaeufer" selectedKey="{create>/einkaeufer}" width="100%">
                        <core:Item key="" text="Bitte wählen..."/>
                        <core:Item key="Anna Schmidt" text="Anna Schmidt"/>
                        <core:Item key="Thomas Müller" text="Thomas Müller"/>
                        <core:Item key="Sarah Weber" text="Sarah Weber"/>
                        <core:Item key="Michael Fischer" text="Michael Fischer"/>
                        <core:Item key="Julia Becker" text="Julia Becker"/>
                      </Select>
                    </VBox>
                  </HBox>
                  <VBox class="sapUiSmallMarginTop">
                    <Label text="Lieferadresse" required="true"/>
                    <Input id="cLieferadresse" value="{create>/lieferadresse}" width="100%" class="sapUiSmallMarginBottom"
                      placeholder="z.B. Hauptlager, Industriestraße 12, 80331 München"/>
                    <Label text="Bemerkungen"/>
                    <TextArea id="cBemerkungen" value="{create>/bemerkungen}" width="100%" rows="3"
                      placeholder="Optional: Zusätzliche Hinweise zur Bestellung"/>
                  </VBox>
                </VBox>
              </content>
            </Panel>

            <!-- Bestellpositionen -->
            <Panel class="sapUiMediumMarginBottom">
              <headerToolbar>
                <Toolbar>
                  <Title text="Bestellpositionen"/>
                  <ToolbarSpacer/>
                  <Button text="Position hinzufügen" icon="sap-icon://add"
                    type="Emphasized" press=".onAddPosition"/>
                </Toolbar>
              </headerToolbar>
              <content>
                <Table items="{create>/positions}" class="sapUiSmallMarginBottom">
                  <columns>
                    <Column width="120px"><Text text="Material-Nr."/></Column>
                    <Column width="200px"><Text text="Materialname"/></Column>
                    <Column width="80px"><Text text="Menge"/></Column>
                    <Column width="80px"><Text text="Einheit"/></Column>
                    <Column width="100px"><Text text="Einzelpreis"/></Column>
                    <Column width="50px"><Text text=""/></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Input value="{create>mat}" placeholder="MAT-1001" width="100%"/>
                        <Input value="{create>name}" placeholder="z.B. Stahl Blech 2mm" width="100%"/>
                        <Input value="{create>qty}" type="Number" change=".onPositionChange" placeholder="0" width="100%"/>
                        <Select selectedKey="{create>unit}" width="100%">
                          <core:Item key="Stk" text="Stk"/>
                          <core:Item key="kg" text="kg"/>
                          <core:Item key="m" text="m"/>
                          <core:Item key="Pack" text="Pack"/>
                          <core:Item key="Set" text="Set"/>
                        </Select>
                        <Input value="{create>price}" type="Number" change=".onPositionChange" placeholder="0.00" width="100%"/>
                        <Button icon="sap-icon://delete" type="Transparent" press=".onRemovePosition"/>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
                <HBox justifyContent="End" class="sapUiSmallMarginEnd">
                  <Label text="Gesamtbetrag:" class="sapUiSmallMarginEnd sapUiBold"/>
                  <Text text="{create>/gesamtbetrag}" class="sapUiBold"/>
                </HBox>
              </content>
            </Panel>

          </VBox>
        </content>
        <beginButton>
          <Button text="Speichern" type="Emphasized" press=".onSaveCreate"/>
        </beginButton>
        <endButton>
          <Button text="Abbrechen" press=".onCancelCreate"/>
        </endButton>
      </Dialog>

    </content>
  </Page>

</mvc:View>